  "news": [
    {
      "title": "茶道入门：为什么盖碗适合观察一款茶",
      "date": "2026-05-22",
      "image": "/assets/gulang-tea-hero.png",
      "video": "",
      "summary": "盖碗方便闻香、观汤与控制出水，是理解茶叶变化的好入口。",
      "detail": "盖碗的优势在于材质中性、开合灵活、便于观察。初学者可以从投茶量、水温、出汤时间三个变量开始建立品饮感受。",
      "status": "published"
    },
    {
      "title": "绿茶、岩茶、白茶的醒茶方式有何不同",
      "date": "2026-05-18",
      "image": "/assets/gulang-tea-hero.png",
      "video": "",
      "summary": "不同茶类对温度、时间和器具的敏感度不同，醒茶方式也应区分。",
      "detail": "绿茶重鲜爽，一般不宜高温久闷；岩茶可通过温杯烫盏唤醒香气；老白茶则可根据年份与紧压程度调整润茶节奏。",
      "status": "published"
    },
    {
      "title": "茶席布置中的留白、动线与器物层次",
      "date": "2026-05-12",
      "image": "/assets/gulang-tea-hero.png",
      "video": "",
      "summary": "一方茶席不在物多，而在主次清楚、取用顺手、气韵安定。",
      "detail": "茶席布置应先确定主器，再处理水盂、茶则、茶巾与杯盏的位置。留白让视线安定，也让冲泡动作更从容。",
      "status": "published"
    }
